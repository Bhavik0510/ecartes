<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_marvex_partner_ledger_form">
            <field name="name">marvex.partner.ledger.form</field>
            <field name="model">marvex.partner.ledger</field>
            <field name="arch" type="xml">
                <form string="Marvex">
                    <sheet>
                        <group>
                            <field name="from_date"/>
                            <field name="to_date"/>
                            <field name="partner_id" options="{'no_create': True}"/>
                        </group>
                        <footer>
                            <button string="Print" type="object" name="action_print" class="btn-primary"/>
                            <button string="Cancel" class="btn-secondary" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_view_marvex_partner_ledger_form" model="ir.actions.act_window">
            <field name="name">Marvex Partner Ledger</field>
            <field name="res_model">marvex.partner.ledger</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_marvex_partner_ledger_form"/>
            <field name="target">new</field>
        </record>

        <menuitem
                id="menu_action_marvex"
                name="New Partner Ledger"
                action="action_view_marvex_partner_ledger_form"
                parent="account.menu_finance_reports"
                sequence="5"
                groups="account.group_account_manager"/>
    </data>
</odoo>