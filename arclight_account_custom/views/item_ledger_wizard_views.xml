<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_account_item_ledger_wizard_form" model="ir.ui.view">
        <field name="name">account.item.ledger.wizard.form</field>
        <field name="model">account.item.ledger</field>
        <field name="arch" type="xml">
            <form string="Item Ledger">
                <sheet>
                    <group>
                        <group>
                            <field name="product_id" options="{'no_create': True}" placeholder="All items"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_print_pdf" string="PDF Report" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_item_ledger_wizard" model="ir.actions.act_window">
        <field name="name">Item Ledger</field>
        <field name="res_model">account.item.ledger</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_account_item_ledger_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>

