<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_move_line_tree_qty_in_out" model="ir.ui.view">
        <field name="name">stock.move.line.tree.qty.in.out</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='location_dest_id']" position="after">
                <field name="qty_in" class="text-success"/>
                <field name="qty_out" class="text-danger"/>
            </xpath>
            <xpath expr="//field[@name='quantity']" position="replace">
                <!-- remove original Quantity column -->
            </xpath>
        </field>
    </record>
</odoo>

