<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Change invoice heading to 'Tax Invoice' on customer invoices -->
        <template id="account_invoice_tax_invoice_title" inherit_id="account.report_invoice_document">
            <!-- Replace the main title inside the main report page -->
            <xpath expr="//div[hasclass('page')]/h2" position="replace">
                <h2>
                    <span t-if="o.move_type == 'out_invoice' and o.state == 'posted'">Tax Invoice</span>
                    <span t-if="o.move_type == 'out_invoice' and o.state == 'draft'">Draft Tax Invoice</span>
                    <span t-if="o.move_type == 'out_invoice' and o.state == 'cancel'">Cancelled Tax Invoice</span>
                    <span t-if="o.move_type == 'out_refund'">Credit Note</span>
                    <span t-if="o.move_type == 'in_refund'">Vendor Credit Note</span>
                    <span t-if="o.move_type == 'in_invoice'">Vendor Bill</span>
                    <span t-if="o.name != '/'" t-field="o.name" style="color:#7c3077;font-weight:800;"/>
                </h2>
            </xpath>
        </template>
    </data>
</odoo>

