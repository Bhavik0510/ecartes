<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="item_ledger_report">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <t t-set="data_report_margin_top" t-value="12"/>
                <t t-set="data_report_header_spacing" t-value="9"/>
                <t t-set="data_report_dpi" t-value="110"/>
                <div class="page">
                    <h3><center><b>Stock Item Ledger Report</b></center></h3>
                    <br/>
                    <t t-set="report_data" t-value="docs.get_report_lines()"/>
                    <t t-set="report_lines" t-value="report_data.get('report_lines', []) if isinstance(report_data, dict) else report_data"/>
                    <t t-set="product_name" t-value="report_data.get('product_name', '') if isinstance(report_data, dict) else ''"/>
                    <t t-set="date_from_str" t-value="report_data.get('date_from_str', '') if isinstance(report_data, dict) else ''"/>
                    <t t-set="date_to_str" t-value="report_data.get('date_to_str', '') if isinstance(report_data, dict) else ''"/>
                    <div class="filters" style="margin-bottom: 15px;">
                        <table class="table table-sm" style="font-size: 11px;">
                            <tr><td><strong>Stock Item:</strong></td><td><t t-esc="product_name"/></td></tr>
                            <tr><td><strong>Date Range:</strong></td><td><t t-esc="date_from_str"/> to <t t-esc="date_to_str"/></td></tr>
                        </table>
                    </div>
                    <t t-if="report_lines">
                        <table class="table table-sm table-bordered" style="font-size: 10px;">
                            <thead style="background: #808080; color: white;">
                                <tr>
                                    <th>Date</th><th>Particulars</th><th>Vch Type</th><th>Vch No.</th>
                                    <th colspan="3" style="text-align:center;">Inwards</th>
                                    <th colspan="3" style="text-align:center;">Outwards</th>
                                    <th colspan="3" style="text-align:center;">Closing</th>
                                </tr>
                                <tr style="background: #a0a0a0;">
                                    <th/><th/><th/><th/>
                                    <th>Qty</th><th>Rate</th><th>Value</th>
                                    <th>Qty</th><th>Rate</th><th>Value</th>
                                    <th>Qty</th><th>Rate</th><th>Value</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="report_lines" t-as="row" t-key="row_index">
                                    <tr>
                                        <td><t t-esc="row.get('date_str', '')"/></td>
                                        <td><t t-esc="row.get('particulars', '')"/></td>
                                        <td><t t-esc="row.get('vch_type', '')"/></td>
                                        <td><t t-esc="row.get('vch_no', '')"/></td>
                                        <td class="text-end"><t t-esc="'%.2f' % row.get('in_qty', 0) if row.get('in_qty') else ''"/></td>
                                        <td class="text-end"><t t-esc="'%.2f' % row.get('in_rate', 0) if row.get('in_rate') else ''"/></td>
                                        <td class="text-end"><t t-esc="'%.2f' % row.get('in_value', 0) if row.get('in_value') else ''"/></td>
                                        <td class="text-end"><t t-esc="'%.2f' % row.get('out_qty', 0) if row.get('out_qty') else ''"/></td>
                                        <td class="text-end"><t t-esc="'%.2f' % row.get('out_rate', 0) if row.get('out_rate') else ''"/></td>
                                        <td class="text-end"><t t-esc="'%.2f' % row.get('out_value', 0) if row.get('out_value') else ''"/></td>
                                        <td class="text-end"><t t-esc="'%.2f' % row.get('close_qty', 0)"/></td>
                                        <td class="text-end"><t t-esc="'%.2f' % row.get('close_rate', 0) if row.get('close_qty') else ''"/></td>
                                        <td class="text-end"><t t-esc="'%.2f' % row.get('close_value', 0)"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                    <t t-else="">
                        <p>No transactions found for the selected item and date range.</p>
                    </t>
                </div>
            </t>
        </t>
    </template>

    <record id="action_print_item_ledger" model="ir.actions.report">
        <field name="name">Item Ledger</field>
        <field name="model">account.item.ledger</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">arclight_account_custom.item_ledger_report</field>
        <field name="report_file">arclight_account_custom.item_ledger_report</field>
        <field name="print_report_name">'Item_Ledger_%s' % (object.product_id.name or 'Report')</field>
    </record>
</odoo>

