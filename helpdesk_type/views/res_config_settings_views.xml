<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_view_form_inherit_select_type" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.helpdesk.select_type</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="helpdesk_mgmt.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//app[@name='helpdesk_mgmt']/block" position="inside">
                <setting>
                    <field name="helpdesk_mgmt_portal_type"/>
                </setting>

                <setting invisible="not helpdesk_mgmt_portal_type">
                    <field name="helpdesk_mgmt_portal_type_id_required" string="Required Type"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
