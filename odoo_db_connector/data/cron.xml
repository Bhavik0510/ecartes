<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_sync_attachments_to_receiver" model="ir.cron">
            <field name="name">Sync Attachments to Receiver Database</field>
            <field name="model_id" ref="base.model_ir_attachment"/>
            <field name="state">code</field>
            <field name="code">model.env['sync.manager'].sync_all_attachments_to_receiver(batch_size=100)</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
