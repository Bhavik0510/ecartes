<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_server_cancel_stock_picking" model="ir.actions.server">
            <field name="name">Cancel Pickings</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="binding_model_id" ref="stock.model_stock_picking"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">records.with_context(Flag=True).action_cancel()
action = False</field>
        </record>

        <record id="action_server_reset_draft_stock_picking" model="ir.actions.server">
            <field name="name">Reset to Draft</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="binding_model_id" ref="stock.model_stock_picking"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">records.action_draft()
action = False</field>
        </record>
    </data>
</odoo>
